{
  "name": "blueticks",
  "version": "3.4.2",
  "description": "Official Node/TypeScript client for the Blueticks API.",
  "keywords": [
    "blueticks",
    "whatsapp",
    "api",
    "sdk"
  ],
  "homepage": "https://blueticks.co",
  "bugs": "https://github.com/serenix-com/blueticks-node/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/serenix-com/blueticks-node.git"
  },
  "license": "MIT",
  "author": "Blueticks <support@blueticks.co>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js",
      "require": "./dist/webhooks.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --max-warnings 0",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
